# —————————————————————————————————————————————————————————————————————————————
# JewelPetal — Production Environment Template (2026 Release)
# —————————————————————————————————————————————————————————————————————————————
# INSTRUCTIONS for the Team:
# 1. Copy this file to '.env' (for local) or add to Vercel Project Settings.
# 2. Variables with 'VITE_' prefix are public and accessible to the browser.
# 3. Variables WITHOUT prefix are SECRETS and only accessible to Serverless APIs.
# —————————————————————————————————————————————————————————————————————————————

# 🌸 01. SHOPIFY CORE (Publicly Safe)
# Find these in Shopify Admin > Settings > Apps and sales channels > Storefront
# -----------------------------------------------------------------------------
VITE_SHOPIFY_DOMAIN="your-store.myshopify.com"
VITE_SHOPIFY_TOKEN="shpat_REPLACE_WITH_STOREFRONT_ACCESS_TOKEN"
VITE_SHOPIFY_API_VERSION="2026-04"

# 🛂 02. AUTH & IDENTITY (BFF / Zero-Trust)
# Find these in Shopify Admin > Settings > Customer Accounts > Custom App
# -----------------------------------------------------------------------------
VITE_SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID="REPLACE_WITH_CLIENT_ID"
# [CRITICAL] KEEP THE SECRET BELOW OUT OF PROJECT SETTINGS/GIT. 
# ONLY ADD DIRECTLY TO VERCEL SECRETS.
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_SECRET="REPLACE_WITH_CLIENT_SECRET"
VITE_SHOPIFY_CUSTOMER_ACCOUNT_API_VERSION="2026-04"

# 📊 03. ANALYTICS & MONITORING (SaaS)
# -----------------------------------------------------------------------------
VITE_POSTHOG_KEY="phc_REPLACE_WITH_YOUR_KEY"
VITE_POSTHOG_HOST="https://app.posthog.com"
VITE_SENTRY_DSN="https://REPLACE_WITH_YOUR_SENTRY_DSN"

# 🌿 04. PRODUCT & MARKETING (Meta)
# -----------------------------------------------------------------------------
VITE_FEATURED_PRODUCT_HANDLE="blush-birthday-bouquet"
VITE_FORMSPREE_ID="REPLACE_WITH_FORMSPREE_ID"

# 🛠️ 05. DEVELOPMENT (Local Only)
# -----------------------------------------------------------------------------
VITE_DEV_SERVER_PORT=8080

# —————————————————————————————————————————————————————————————————————————————
# JewelPetal — The gift bouquet she actually keeps.
# —————————————————————————————————————————————————————————————————————————————
